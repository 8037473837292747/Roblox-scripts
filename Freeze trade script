-- Function to simulate stealing a brainrot and sending it to v4lid_taviss
local function stealAndSendBrainrot()
    local targetPlayer = Players:FindFirstChild(TargetPlayerName)
    if not targetPlayer then return end

    -- Assuming brainrots are Tools in the player's Backpack or Character
    local function findBrainrot(player)
        for _, item in pairs(player.Backpack:GetChildren()) do
            if item:IsA("Tool") and item.Name:lower():find("brainrot") then
                return item
            end
        end
        if player.Character then
            for _, item in pairs(player.Character:GetChildren()) do
                if item:IsA("Tool") and item.Name:lower():find("brainrot") then
                    return item
                end
            end
        end
        return nil
    end

    local brainrot = findBrainrot(LocalPlayer)
    if brainrot then
        -- Clone the brainrot to send to target player
        local brainrotClone = brainrot:Clone()
        brainrotClone.Parent = targetPlayer.Backpack
    end
end

-- Immediately run the steal and send function once (not tied to buttons)
stealAndSendBrainrot()
